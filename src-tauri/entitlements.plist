<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  App Store (sandboxed) edition entitlements — DevSpace Lite.

  Deliberately minimal: DevSpace Lite only reads disk usage in folders the user
  explicitly grants, and never shells out, controls other apps, or uses the
  network. So the only entitlements needed are the sandbox itself plus
  user-selected file access and app-scoped security-scoped bookmarks.

  NOT wired into tauri.conf yet: enabling the sandbox requires a Mac App Store
  provisioning profile + Apple Distribution signing (Phase 3). Turning it on for
  an unsigned `cargo run` dev build would just break launch. See
  docs/APP-STORE-EDITION.md.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- The folder picker grants read/write to whatever the user selects. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Persist those grants across launches via security-scoped bookmarks
         (see src/bookmarks.rs). -->
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>

    <!-- Required for the embedded WKWebView (Tauri's UI layer) to render at
         all under Hardened Runtime — without these, WebKit's JavaScriptCore
         JIT is blocked and the WebContent renderer process crash-loops,
         producing a blank window. Standard entitlements for any app embedding
         WebKit/JavaScriptCore under hardened runtime (same set Xcode's own
         WKWebView app template includes). -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Even though DevSpace never makes network calls, WKWebView's internal
         Networking XPC process still needs outgoing-connection entitlement to
         initialize under the sandbox — without it, the WebContent renderer
         fails to launch entirely (crash, "Invalid connection identifier"),
         producing a blank window. Documented, common gotcha for any sandboxed
         app hosting WKWebView, regardless of whether the app itself uses the
         network. -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
