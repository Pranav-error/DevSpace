{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevSpace",
  "version": "0.1.0",
  "identifier": "com.saipranav.devspace",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": false,
    "windows": [
      {
        "label": "popover",
        "title": "DevSpace",
        "width": 340,
        "height": 384,
        "visible": false,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#1c1c1e",
        "resizable": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "Developer ID Application: MYSTARTUPWAVE PRIVATE LIMITED (J73FA7VZPP)"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
